{
  "outputDirectory": "dist/web/browser",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://revenuesync-api.onrender.com/api/$1"
    },
    {
      "src": "/auth/(.*)",
      "dest": "https://revenuesync-api.onrender.com/auth/$1"
    },
    {
      "src": "/oauth2/(.*)",
      "dest": "https://revenuesync-api.onrender.com/oauth2/$1"
    },
    {
      "src": "/login/oauth2/(.*)",
      "dest": "https://revenuesync-api.onrender.com/login/oauth2/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
