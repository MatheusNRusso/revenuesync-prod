{
  "outputDirectory": "dist/web/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://revenuesync-api.onrender.com/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://revenuesync-api.onrender.com/auth/:path*"
    },
    {
      "source": "/oauth2/:path*",
      "destination": "https://revenuesync-api.onrender.com/oauth2/:path*"
    },
    {
      "source": "/login/oauth2/:path*",
      "destination": "https://revenuesync-api.onrender.com/login/oauth2/:path*"
    }
  ]
}
